generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Website {
  id        String   @id @default(uuid())
  url       String   @unique
  createdAt DateTime @default(now())
  analyses  Analysis[]
}

model Analysis {
  id        String   @id @default(uuid())
  websiteId String
  website   Website  @relation(fields: [websiteId], references: [id])
  createdAt DateTime @default(now())
  data String
}